{
  "name": "git-cascade",
  "version": "0.0.3",
  "description": "Multi-agent git tracking system for coordinating AI agents on shared codebases",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "RUN_SLOW_TESTS=true vitest run",
    "test:e2e": "RUN_SLOW_TESTS=true vitest run tests/e2e",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prerelease": "npm run test:run && npm run build",
    "release:patch": "npm run prerelease && npm version patch && git push && git push --tags",
    "release:minor": "npm run prerelease && npm version minor && git push && git push --tags",
    "release:major": "npm run prerelease && npm version major && git push && git push --tags",
    "release:dry": "npm run prerelease && echo 'Dry run complete - ready to release'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexngai/git-cascade.git"
  },
  "keywords": [
    "git",
    "multi-agent",
    "ai",
    "version-control",
    "coordination"
  ],
  "author": "Alex Ngai",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexngai/git-cascade/issues"
  },
  "homepage": "https://github.com/alexngai/git-cascade#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
